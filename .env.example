# ===== DeepSeek V4 Pro (default LLM backend) =====
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-v4-pro
LLM_BACKEND=deepseek

# ===== Kimi / Moonshot (optional, used by OCR/Vision workflows) =====
# MOONSHOT_API_KEY=sk-your-moonshot-key
# MOONSHOT_API_BASE=https://api.moonshot.cn/v1
# LLM_MODEL_NAME=kimi-k2.6
# KIMI_VISION_MODEL=kimi-k2.5

# ===== OpenAI API (optional alternative backend) =====
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_API_BASE=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# ===== Ollama local model (optional alternative backend) =====
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL_NAME=qwen2.5:7b

# ===== Embedding model =====
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5

# ===== Local data paths =====
DATA_DIR=./data
VECTOR_DB_PATH=./data/vector_db
BOOKS_PATH=./data/books
CHAPTERS_PATH=./data/chapters
PROGRESS_PATH=./data/progress
IMAGES_PATH=./data/images

# Desktop/offline mode defaults to local-only embedding files.
# Set to 0 only when the machine can download embeddings into data/models.
EMBEDDING_LOCAL_FILES_ONLY=1

# ===== MinerU / OCR external APIs (optional) =====
# MINERU_API_URL=http://host.docker.internal:9001
# Optional CLI fallback; command must write MinerU outputs under {output}
# MINERU_CLI_COMMAND=mineru -p "{input}" -o "{output}" -m auto
MINERU_OUTPUT_PATH=./mineru_output
MINERU_TASK_TIMEOUT_SECONDS=3600
MINERU_TASK_POLL_SECONDS=2
# OCR_API_URL=http://host.docker.internal:9002

# ===== Mistake OCR image preprocessing =====
MISTAKE_OCR_MAX_SIDE=1600
MISTAKE_OCR_JPEG_QUALITY=86

# ===== API access boundary =====
# Electron generates and injects a per-launch token automatically. Plain
# loopback development requests remain available unless token enforcement is
# enabled. Set a strong random token before exposing the service to a LAN.
# KAOYAN_API_TOKEN=replace-with-a-long-random-token
# Set to 1 to require the token even on loopback.
KAOYAN_REQUIRE_API_TOKEN=0
# KAOYAN_ALLOW_PRIVATE_CLIENTS is reserved for loopback-bound Docker networking.
