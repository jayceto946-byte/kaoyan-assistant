# ===== DeepSeek V4 Pro (鎬濊€冩ā寮忥紝榛樿涓?LLM) =====
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-v4-pro
LLM_BACKEND=deepseek

# ===== Kimi K2.6 (澶囩敤锛屾敮鎸佸妯℃€? =====
# MOONSHOT_API_KEY=sk-your-moonshot-key
# MOONSHOT_API_BASE=https://api.moonshot.cn/v1
# LLM_MODEL_NAME=kimi-k2.6
# KIMI_VISION_MODEL=kimi-k2.5

# ===== OpenAI API =====
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_API_BASE=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# ===== Ollama 鏈湴妯″瀷 =====
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL_NAME=qwen2.5:7b

# ===== 宓屽叆妯″瀷 =====
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5

# ===== 瀛樺偍璺緞 =====
DATA_DIR=./data
VECTOR_DB_PATH=./data/vector_db
BOOKS_PATH=./data/books
CHAPTERS_PATH=./data/chapters
PROGRESS_PATH=./data/progress
IMAGES_PATH=./data/images

# Docker: set to 0 on a new machine to allow downloading embeddings into data/models
EMBEDDING_LOCAL_FILES_ONLY=1

# ===== MinerU / OCR external APIs (optional) =====
# MINERU_API_URL=http://host.docker.internal:9001
# Optional CLI fallback; command must write MinerU outputs under {output}
# MINERU_CLI_COMMAND=mineru -p "{input}" -o "{output}" -m auto
MINERU_OUTPUT_PATH=./mineru_output
MINERU_TASK_TIMEOUT_SECONDS=3600
MINERU_TASK_POLL_SECONDS=2
# OCR_API_URL=http://host.docker.internal:9002
# ===== 閿欓鍥剧墖 OCR 鍘嬬缉 =====
MISTAKE_OCR_MAX_SIDE=1600
MISTAKE_OCR_JPEG_QUALITY=86
