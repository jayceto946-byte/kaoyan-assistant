{
  "name": "kaoyan-assistant-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for kaoyan-assistant.",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "dev:existing": "set KAOYAN_SKIP_BACKEND=1&& electron .",
    "dev:vite": "set KAOYAN_SKIP_BACKEND=1&& set KAOYAN_FRONTEND_DEV_URL=http://127.0.0.1:5173&& electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable",
    "publish": "electron-builder --win nsis -p always"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "local.kaoyan.assistant",
    "productName": "考研智能辅助系统",
    "artifactName": "kaoyan-assistant-desktop-setup-${version}.${ext}",
    "directories": {
      "output": "../release"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "loading.html",
      "update-config.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../build/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_OWNER",
        "repo": "kaoyan-assistant",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "考研智能辅助系统",
      "deleteAppDataOnUninstall": false
    }
  }
}